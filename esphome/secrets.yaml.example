# Copy this file to secrets.yaml and fill in your values
# DO NOT commit secrets.yaml to version control!

# WiFi credentials
wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# Fallback AP SSID and password
esphome_ap_ssid: "growatt-sunspec"
esphome_ap_password: "sunspec123"

# Home Assistant API encryption key (generate with: openssl rand -hex 32)
esphome_api_key: "your_32_byte_hex_key_here"

# OTA update password
esphome_ota_password: "your_ota_password"
